# %% [markdown]
# Section 2 - Data Cleaning

# %%
#Check missing values in the dataset, because most of the time the real SCADA data is real messy
#how many values in the dataset have NaN
df.isnull().sum()

# %%
#Power cannot be negative. Find rows where "ac_power_kw" is less than 0. These are sensor errors 
#Count how many of the values in the ac power have 0 values
(df["ac_power_kw"]<0).sum()

# %%
(df["dc_power_kw"]<0).sum()

# %%
df.loc[df["ac_power_kw"]<0, "ac_power_kw"] = np.nan

# %%
#The column "dc_voltage_v" has some impossible spikes above 800 volts. Real inverter voltage is below 800V 
(df["dc_voltage_v"]>800).sum()

# %%
df.loc[df["dc_voltage_v"]>800,"dc_voltage_v"] = np.nan

# %%
df.isnull().sum()

# %%
#Fill in missing values [NaN],
#      "ghi_w_m2"     - forward fill, then fill leftover with 0
#      "t_module_c"   - forward fill, then backward fill
#      "ac_power_kw"  - fill with 0
#      "dc_voltage_v" - forward fill

df["ghi_w_m2"] = df["ghi_w_m2"].ffill().fillna(0)
df["t_module_c"] = df["t_module_c"].ffill().bfill()
df["ac_power_kw"] = df["ac_power_kw"].fillna(0)
df["dc_voltage_v"] = df["dc_voltage_v"].ffill()

# %%
df.duplicated().sum()

# %%
df.duplicated(subset = ["timestamp","inverter_id"]).sum()

# %%
df = df.drop_duplicates(subset = ["timestamp","inverter_id"])

# %%
#two sums give the sum of the entire list
df.isnull().sum().sum()

