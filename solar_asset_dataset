df.shape

# %% [markdown]
# Section 3 - Feature Engineering

# %% [markdown]
# Create new column called energy_kwh

# %%
df

# %%
df.columns

# %%
#5/60 is done because we are converting 5 minutes to hours
#This will tell us how much electricity is produced in each 5 minute produced
df["energy_kwh"] = df["ac_power_kw"] * (5/60)

# %%
df["ac_power_kw"].unique()

# %%
daily = df.groupby("date")["energy_kwh"].sum().reset_index()

# %%
daily

# %%
daily.columns = ["date","energy_kwh"]

# %%
daily.columns

# %% [markdown]
# Add more daily columns to check your daily dataframe 

# %%
daily["ghi_w_m2"] = df.groupby("date")["ghi_w_m2"].sum().values*(5/60)/10

# %%
daily["ghi_w_m2"]

# %%
daily["fault_count"] = df.groupby("date")["fault_flag"].sum().values
daily["fault_count"]

# %%
daily["avg_temp"] = df.groupby("date")["t_module_c"].mean().values

# %%
daily["avg_temp"]

# %% [markdown]
# Calculate CUF - Capacity Utilization Factor 

# %% [markdown]
# CUF calculates out of all the hours of the day(24 hours), when fraction of the plant was producing power?
# 
# 
# CUF(%) = energy_kwh / (1000kW * 24) * 100 
# 
# A CUF of 20% means the plant ran at full capacity
# 
# A PR of above 75% is considered good

# %%
daily["cuf_pct"] = (daily["energy_kwh"]/(1000*24))*100

# %%
daily["cuf_pct"].unique()


# %% [markdown]
# Calculate PR (Performance Ratio) for each day.
# 
# PR tells you: How efficiently the sunlight energy was converted to electricity?

# %%
#Reference Yield - how much sun was available
daily["ref_yield"] = daily["ghi_w_m2"]/1000

# %%
#Actual Yield - how much was converted to electricity
daily["act_yield"] = daily["energy_kwh"]/1000

# %% [markdown]
# syntax: np.where(condition, value_if_true, value_if_false)

# %%
#Calculate PR percentage 
daily["pr_pct"] = (daily["act_yield"]/daily["ref_yield"])*100
daily["pr_pct"] = np.where(daily["ref_yield"] > 0, (daily["act_yield"] / daily["ref_yield"])*100, np.nan)

# %%
daily["pr_pct"].unique()

# %%
print(daily[["date", "ghi_w_m2", "ref_yield", "act_yield", "pr_pct"]].head(5))

# %%
#Extract month from date column 
daily["month"] = pd.to_datetime(daily["date"]).dt.month

# %%
daily["month"].unique()

# %%
#converted the month numbers to month names
daily["month_name"] = pd.to_datetime(daily["date"]).dt.strftime("%b")

# %%
daily["month_name"]

# %%
#maps the seasons month to the seaons
season_map = {
           12: "Winter", 1: "Winter",  2: "Winter",
           3: "Spring", 4: "Spring",  5: "Spring",
           6: "Summer", 7: "Summer",  8: "Summer",
           9: "Autumn",10: "Autumn", 11: "Autumn",
}

daily["seasons"] = daily["month"].map(season_map)

# %%
daily["seasons"].unique()

